<resources>
    <style name="Theme.HabitosAlimenticios" parent="Theme.Material3.Light.NoActionBar">
        <!-- Color primario: verde hoja -->
        <item name="colorPrimary">@color/green_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/green_200</item>
        <item name="colorOnPrimaryContainer">@color/green_900</item>
        <!-- Color secundario: tono tierra -->
        <item name="colorSecondary">@color/brown_500</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/brown_100</item>
        <item name="colorOnSecondaryContainer">@color/brown_900</item>
        <!-- Fondo y superficie -->
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/grey_900</item>
        <!-- Tipografía -->
        <item name="fontFamily">@font/roboto_regular</item>
        <item name="android:fontFamily">@font/roboto_regular</item>
        <!-- Forma de componentes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Large</item>
    </style>

    <style name="ShapeAppearance.Small" parent="ShapeAppearance.Material3.Corner.Small">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    <style name="ShapeAppearance.Medium" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeAppearance.Large" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    <style name="NavDrawerTextStyle" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/lato_bold</item>
        <item name="android:textColor">@color/grey_900</item>
    </style>
    <color name="nav_item_tint">@color/green_700</color>
</resources>